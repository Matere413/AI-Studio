        "title": "Load Foreground"
      }
    },
    "3": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "",
        "clip": [
          "10",
          0
        ]
      },
      "_meta": {
        "title": "CLIP Text Encode (Prompt)"
      }
    },
    "4": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "",
        "clip": [
          "10",
          0
        ]
      },
