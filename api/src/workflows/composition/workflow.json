        "vae": [
          "9",
          0
        ]
      },
      "_meta": {
        "title": "VAE Encode Foreground"
      }
    },
    "18": {
      "class_type": "DepthAnythingV2Preprocessor",
      "inputs": {
        "images": [
          "1",
          0
        ],
        "resolution": 512
      },
      "_meta": {
        "title": "Depth Preprocessor"
      }
    },
    "19": {
      "class_type": "CannyEdgePreprocessor",
      "inputs": {
        "images": [
          "1",
          0
        ],
