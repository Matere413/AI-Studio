    "11": {
      "class_type": "KSampler",
      "inputs": {
        "seed": 0,
        "steps": 25,
        "cfg": 3.5,
        "sampler_name": "euler",
        "scheduler": "normal",
        "denoise": 1.0,
        "model": [
          "8",
          0
        ],
        "positive": [
          "15",
          0
        ],
        "negative": [
          "4",
          0
        ],
        "latent_image": [
          "17",
          0
        ]
      },
      "_meta": {
        "title": "KSampler (FLUX + ControlNet)"
      }
    },
    "12": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": [
          "11",
          0
        ],
        "vae": [
          "9",
          0
        ]
      },
      "_meta": {
        "title": "VAE Decode"
      }
    },
    "13": {
      "class_type": "SaveImage",
      "inputs": {
        "filename_prefix": "composition/",
        "images": [
          "12",
          0
        ]
      },
      "_meta": {
        "title": "Save Image"
